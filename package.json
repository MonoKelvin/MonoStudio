{
    "name": "monostudio",
    "version": "1.0.0",
    "description": "A desktop toolbox application",
    "main": "electron/main.js",
    "scripts": {
        "renderer:dev": "vite --port 5173",
        "electron:dev": "npx cross-env VITE_DEV_SERVER_URL=http://localhost:5173 npx electron .",
        "desktop:dev": "npx concurrently -k \"npm:renderer:dev\" \"npx wait-on http-get://localhost:5173 && npx cross-env VITE_DEV_SERVER_URL=http://localhost:5173 npx electron .\"",
        "desktop:dev:port": "npx concurrently -k \"npm:renderer:dev\" \"npx wait-on http-get://localhost:5173 && npx cross-env VITE_DEV_SERVER_URL=http://localhost:5173 npx electron .\"",
        "desktop:dev:renderer": "npm run renderer:dev",
        "build": "vite build",
        "desktop:build": "npm run build && electron-builder",
        "desktop:pack": "npm run build && electron-builder --dir",
        "start": "npm run desktop:dev",
        "electron": "npm run desktop:dev",
        "dev": "npm run desktop:dev"
    },
    "keywords": [
        "electron",
        "vue",
        "toolbox"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@fullcalendar/core": "^6.1.20",
        "@fullcalendar/daygrid": "^6.1.20",
        "@fullcalendar/interaction": "^6.1.20",
        "@fullcalendar/list": "^6.1.20",
        "@fullcalendar/timegrid": "^6.1.20",
        "@fullcalendar/vue3": "^6.1.20",
        "@tiptap/extension-highlight": "^2.10.0",
        "@tiptap/extension-link": "^2.10.0",
        "@tiptap/extension-placeholder": "^2.10.0",
        "@tiptap/extension-task-item": "^2.10.0",
        "@tiptap/extension-task-list": "^2.10.0",
        "@tiptap/extension-underline": "^2.10.0",
        "@tiptap/starter-kit": "^2.10.0",
        "@tiptap/vue-3": "^2.10.0",
        "systeminformation": "^5.31.5",
        "vue": "^3.5.13"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.2.1",
        "concurrently": "^9.1.2",
        "cross-env": "^7.0.3",
        "electron": "^32.1.2",
        "electron-builder": "^24.13.3",
        "vite": "^5.4.11",
        "wait-on": "^8.0.3"
    },
    "build": {
        "appId": "com.monostudio.app",
        "productName": "MonoStudio",
        "directories": {
            "output": "dist_electron",
            "buildResources": "build"
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "win": {
            "target": "portable",
            "signAndEditExecutable": false
        },
        "portable": {
            "artifactName": "MonoStudio-${version}.exe"
        }
    },
    "type": "commonjs"
}
